# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/apex_sdn"

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="change_me_access_secret_min_32_chars"
JWT_REFRESH_SECRET="change_me_refresh_secret_min_32_chars"

# Ryu SDN controller REST API base URL
RYU_URL="http://localhost:8080"

# Express server
PORT=3000
NODE_ENV=development

# Frontend origin (used for CORS)
FRONTEND_URL="http://localhost:5173"
